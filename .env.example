# === Mantle Sepolia (on-chain logging) ===
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_CHAIN_ID=5003
AGENT_PRIVATE_KEY=your_mantle_wallet_private_key
AGENT_CFO_CONTRACT_ADDRESS=0xYourDeployedContract

# === Byreal / Solana (live swaps) ===
BYREAL_WALLET_ADDRESS=your_solana_wallet_address
BYREAL_CLI_PATH=byreal-cli
SIMULATION_MODE=true

# === Production ===
PORT=3847
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# === Telegram Bot ===
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_BOT_USERNAME=my_mantle_cfo_bot
AGENT_API_URL=https://personal-cfoagent-production.up.railway.app

# === Web (Vercel) ===
NEXT_PUBLIC_AGENT_API=https://your-agent.up.railway.app
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContract
NEXT_PUBLIC_MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz

# === Agent (local / bot) ===
AGENT_API_PORT=3847
AGENT_API_HOST=0.0.0.0
AGENT_API_URL=https://your-agent.up.railway.app
